# Database
DATABASE_URL=postgresql://qima_user:qima_password@127.0.0.1:15432/qima

# Recipe Discussion Configuration (Groq is the default provider)
RECIPE_DISCUSSION_PROVIDER=groq
RECIPE_DISCUSSION_MODEL=llama-3.1-8b-instant
RECIPE_DISCUSSION_TIMEOUT_SECONDS=20
RECIPE_DISCUSSION_TEMPERATURE=0.2
RECIPE_DISCUSSION_MAX_TOKENS=700
RECIPE_DISCUSSION_MAX_RETRIES=2

# API keys (backend only)
GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here
GEMINI_REQUEST_TIMEOUT_SECONDS=20
GEMINI_INLINE_IMAGE_MAX_BYTES=18000000
OPENAI_API_KEY=your_openai_key_here

# Open Food Facts
OPENFOODFACTS_BASE_URL=https://world.openfoodfacts.org
OPENFOODFACTS_USER_AGENT=Qima/1.0 (your-email@example.com)

# App config
APP_ENV=development
APP_DEBUG=true
APP_NAME=Qima API
QIMA_RECIPE_DEBUG_ENABLED=false

# Auth/JWT
JWT_SECRET=replace_me_with_strong_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXP_MINUTES=60

# Legacy email verification settings kept for compatibility.
# The current local auth flow does not require email verification before login.
VERIFICATION_SECRET=replace_me_with_strong_verification_secret
VERIFICATION_TOKEN_TTL_MINUTES=30
VERIFICATION_RESEND_COOLDOWN_SECONDS=60

# Legacy email verification provider settings
EMAIL_PROVIDER=smtp
EMAIL_FROM=no-reply@qima.local
EMAIL_VERIFY_BASE_URL=http://localhost:5173/verify-email
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
