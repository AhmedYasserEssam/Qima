{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/v1/prices_estimate.json",
  "title": "Prices Estimate API Contract V1",
  "description": "Contract-first schema for POST /v1/prices/estimate request and response. This endpoint estimates ingredient, recipe, or pantry-delta cost using backend-normalized price data. It remains available as a direct integration/testing endpoint and as a reusable backend orchestration capability.",
  "type": "object",
  "additionalProperties": false,
  "required": ["endpoint", "method", "request", "responses"],
  "properties": {
    "endpoint": {
      "const": "/v1/prices/estimate"
    },
    "method": {
      "const": "POST"
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contentType", "body"],
      "properties": {
        "contentType": {
          "const": "application/json"
        },
        "body": {
          "$ref": "#/$defs/PricesEstimateRequest"
        }
      }
    },
    "responses": {
      "type": "object",
      "additionalProperties": false,
      "required": ["200", "400", "404", "422", "429", "500", "503"],
      "properties": {
        "200": {
          "type": "object",
          "additionalProperties": false,
          "required": ["description", "body"],
          "properties": {
            "description": {
              "const": "Successful price estimate"
            },
            "body": {
              "$ref": "#/$defs/PricesEstimateSuccess"
            }
          }
        },
        "400": { "$ref": "#/$defs/ErrorResponseSpec" },
        "404": { "$ref": "#/$defs/ErrorResponseSpec" },
        "422": { "$ref": "#/$defs/ErrorResponseSpec" },
        "429": { "$ref": "#/$defs/ErrorResponseSpec" },
        "500": { "$ref": "#/$defs/ErrorResponseSpec" },
        "503": { "$ref": "#/$defs/ErrorResponseSpec" }
      }
    }
  },
  "$defs": {
    "PricesEstimateRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["price_basis", "budget"],
      "properties": {
        "price_basis": {
          "$ref": "shared_price_context.json#/$defs/PriceBasis"
        },
        "ingredients": {
          "type": "array",
          "description": "Direct ingredient list for ingredient-list estimation.",
          "items": {
            "$ref": "shared_price_context.json#/$defs/RequestedIngredient"
          }
        },
        "recipe_id": {
          "type": "string",
          "minLength": 1,
          "description": "Backend recipe identifier when estimating a stored or retrieved recipe."
        },
        "recipe_ingredients": {
          "type": "array",
          "description": "Recipe ingredient list when recipe_id is unavailable or not persisted yet.",
          "items": {
            "$ref": "shared_price_context.json#/$defs/RequestedIngredient"
          }
        },
        "pantry": {
          "type": "array",
          "description": "Ingredients already owned by the user. Used to compute pantry-delta cost.",
          "items": {
            "$ref": "shared_price_context.json#/$defs/RequestedIngredient"
          },
          "default": []
        },
        "budget": {
          "allOf": [
            {
              "$ref": "shared_price_context.json#/$defs/BudgetPreference"
            },
            {
              "required": ["geography"]
            }
          ]
        },
        "price_preferences": {
          "$ref": "shared_price_context.json#/$defs/PricePreferences"
        },
        "servings": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Optional number of servings used to scale or report per-serving cost. Supports partial servings such as 0.5."
        },
        "currency": {
          "type": "string",
          "minLength": 3,
          "maxLength": 3,
          "default": "EGP",
          "description": "Requested currency. v1 does not perform currency conversion."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "price_basis": {
                "const": "ingredient_list"
              }
            },
            "required": ["price_basis"]
          },
          "then": {
            "required": ["ingredients"],
            "properties": {
              "ingredients": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "price_basis": {
                "const": "recipe_id"
              }
            },
            "required": ["price_basis"]
          },
          "then": {
            "required": ["recipe_id"]
          }
        },
        {
          "if": {
            "properties": {
              "price_basis": {
                "const": "recipe_ingredients"
              }
            },
            "required": ["price_basis"]
          },
          "then": {
            "required": ["recipe_ingredients"],
            "properties": {
              "recipe_ingredients": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "price_basis": {
                "const": "pantry_delta"
              }
            },
            "required": ["price_basis"]
          },
          "then": {
            "anyOf": [
              {
                "required": ["ingredients"],
                "properties": {
                  "ingredients": {
                    "minItems": 1
                  }
                }
              },
              {
                "required": ["recipe_ingredients"],
                "properties": {
                  "recipe_ingredients": {
                    "minItems": 1
                  }
                }
              },
              {
                "required": ["recipe_id"]
              }
            ]
          }
        }
      ]
    },
    "PricesEstimateSuccess": {
      "type": "object",
      "additionalProperties": false,
      "required": ["estimate_id", "price_basis", "estimated_cost", "latency_ms"],
      "properties": {
        "estimate_id": {
          "type": "string",
          "minLength": 1,
          "description": "Backend identifier for the generated price estimate."
        },
        "price_basis": {
          "$ref": "shared_price_context.json#/$defs/PriceBasis"
        },
        "recipe_id": {
          "type": "string",
          "description": "Recipe id used for the estimate when available."
        },
        "estimated_cost": {
          "$ref": "shared_price_context.json#/$defs/EstimatedCost"
        },
        "warnings": {
          "type": "array",
          "description": "Endpoint-level warnings not already represented inside estimated_cost.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "latency_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Backend end-to-end latency in milliseconds."
        }
      }
    },
    "ErrorResponseSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "body"],
      "properties": {
        "description": {
          "type": "string"
        },
        "body": {
          "$ref": "contracts/v1/error_response.json"
        }
      }
    }
  }
}